rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdminBootstrapEmail() {
      return isSignedIn() && request.auth.token.email == "kutluozgur79@gmail.com";
    }

    function isApprovedTeacherEmail() {
      return isSignedIn() && request.auth.token.email in [
        "kutluozgur79@gmail.com",
        "ncheleby73@gmail.com",
        "huseyincimen71@gmail.com",
        "teacher@gmail.com"
      ];
    }

    function isTeacherWhitelisted() {
      return isApprovedTeacherEmail() ||
        (
          isSignedIn() &&
          exists(/databases/$(database)/documents/staffEmails/$(request.auth.token.email))
        );
    }

    function currentRole() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return currentRole() == "admin";
    }

    function isTeacher() {
      return currentRole() == "teacher";
    }

    function isStaff() {
      return isAdmin() || isTeacher();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function myAssignedTeacherId() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.assignedTeacherId
        : null;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) ||
        isAdmin() ||
        isAdminBootstrapEmail() ||
        (isSignedIn() && myAssignedTeacherId() == userId) ||
        (isTeacher() && (
          resource.data.assignedTeacherId == request.auth.uid ||
          resource.data.assignedTeacherEmail == request.auth.token.email ||
          userId == request.auth.uid
        ));

      allow create: if isOwner(userId) &&
        (
          request.resource.data.role == "student" ||
          (request.resource.data.role in ["teacher", "admin"] && isTeacherWhitelisted())
        );

      allow update: if isAdmin() ||
        isAdminBootstrapEmail() ||
        (
          isOwner(userId) &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.assignedTeacherId == ("assignedTeacherId" in resource.data ? resource.data.assignedTeacherId : null) &&
          request.resource.data.assignedTeacherName == ("assignedTeacherName" in resource.data ? resource.data.assignedTeacherName : "") &&
          request.resource.data.assignedTeacherEmail == ("assignedTeacherEmail" in resource.data ? resource.data.assignedTeacherEmail : "")
        );

      allow delete: if isAdmin() || isAdminBootstrapEmail();
    }

    match /staffEmails/{emailId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isAdminBootstrapEmail();
    }

    match /quizzes/{quizId} {
      allow create: if isStaff() && request.resource.data.createdBy == request.auth.uid;
      allow read: if isAdmin() ||
        (isTeacher() && resource.data.createdBy == request.auth.uid) ||
        (isSignedIn() && request.auth.uid in resource.data.accessibleUserIds);
      allow update: if isAdmin() || (isTeacher() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin() ||
        isAdminBootstrapEmail() ||
        (isTeacher() && resource.data.createdBy == request.auth.uid);
    }

    match /attempts/{attemptId} {
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        currentRole() == "student";
      allow read: if isAdmin() ||
        (isTeacher() && (
          resource.data.teacherId == request.auth.uid ||
          resource.data.teacherEmail == request.auth.token.email
        )) ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || isAdminBootstrapEmail();
      allow delete: if isAdmin() || isAdminBootstrapEmail();
    }

    match /projects/{projectId} {
      allow create: if (
        isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        currentRole() == "student"
      ) || isStaff() || isAdminBootstrapEmail();
      allow read: if isAdmin() ||
        (isTeacher() && (
          resource.data.teacherId == request.auth.uid ||
          resource.data.teacherEmail == request.auth.token.email ||
          (
            exists(/databases/$(database)/documents/users/$(resource.data.userId)) &&
            get(/databases/$(database)/documents/users/$(resource.data.userId)).data.assignedTeacherEmail == request.auth.token.email
          )
        )) ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin() ||
        (isTeacher() && (
          resource.data.teacherId == request.auth.uid ||
          resource.data.teacherEmail == request.auth.token.email
        )) ||
        (
          isSignedIn() &&
          currentRole() == "student" &&
          resource.data.userId == request.auth.uid &&
          request.resource.data.userId == request.auth.uid
        );
      allow delete: if isAdmin() || isAdminBootstrapEmail();
    }

    match /messages/{messageId} {
      allow create: if isSignedIn() &&
        request.resource.data.senderId == request.auth.uid &&
        (
          (currentRole() == "student" && request.resource.data.studentId == request.auth.uid) ||
          (isTeacher() && (
            request.resource.data.teacherId == request.auth.uid ||
            request.resource.data.teacherEmail == request.auth.token.email
          )) ||
          isAdmin()
        );
      allow read: if isAdmin() ||
        (isTeacher() && (
          resource.data.teacherId == request.auth.uid ||
          resource.data.teacherEmail == request.auth.token.email
        )) ||
        (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow update: if isAdmin() || isAdminBootstrapEmail();
      allow delete: if isAdmin() || isAdminBootstrapEmail();
    }
  }
}

